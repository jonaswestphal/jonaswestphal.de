---
import Layout from "@/layouts/Layout.astro";
import { getContent } from "@/lib/content";
import Button from "@/components/starwind/button/Button.astro";

const content = getContent("de");
const { thankYou } = content;
---

<Layout locale="de">
	<section class="py-12 sm:py-16 md:py-20 lg:py-24">
		<div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
			<!-- Success Icon -->
			<div class="mb-8">
				<div class="mx-auto flex size-20 items-center justify-center rounded-full bg-primary/10">
					<svg xmlns="http://www.w3.org/2000/svg" class="size-10 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
				</div>
			</div>

			<h1 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-6">
				{thankYou.headline}
			</h1>

			<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed mb-10 max-w-2xl mx-auto">
				{thankYou.message}
			</p>

			<Button variant="primary" size="lg" href={thankYou.ctaHref}>
				{thankYou.ctaLabel}
			</Button>
		</div>
	</section>
</Layout>
