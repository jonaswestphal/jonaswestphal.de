---
import { getContent } from "@/lib/content";
import type { Locale } from "@/lib/types";
import ServiceCard from "./ServiceCard.astro";

interface Props {
  locale?: Locale;
}

const { locale = "de" } = Astro.props;
const content = getContent(locale);
const { services } = content;
---

<section id="services" class="py-12 sm:py-16 md:py-20 lg:py-24">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Section Header -->
		<div class="max-w-3xl mx-auto text-center mb-12 sm:mb-16">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6">
				{services.sectionTitle}
			</h2>
			<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
				{services.sectionSubtitle}
			</p>
		</div>

		<!-- Service Cards Grid -->
		<div class="grid gap-6 sm:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
			{services.items.map((service) => (
				<ServiceCard service={service} />
			))}
		</div>
	</div>
</section>
