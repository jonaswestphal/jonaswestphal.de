---
import { getContent } from "@/lib/content";
import type { Locale } from "@/lib/types";
import Logo from "./Logo.astro";

interface Props {
  locale?: Locale;
}

const { locale = "de" } = Astro.props;
const content = getContent(locale);
const { brandText, legalLinks, socialLinks, contactInfo, cookieSettingsLabel, copyright } = content.footer;
---

<footer class="border-t border-border bg-background py-12 sm:py-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Footer Content -->
    <div class="grid gap-8 mb-8 md:grid-cols-3">
      <!-- Brand Section -->
      <div class="flex flex-col items-start gap-4">
        <a href={locale === "en" ? "/en/" : "/"} class="flex items-center" aria-label={brandText}>
          <Logo />
        </a>
        <p class="text-sm text-muted-foreground max-w-xs">
          {brandText}
        </p>
        <!-- Contact Email -->
        <a
          href={`mailto:${contactInfo.email}`}
          class="text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          {contactInfo.email}
        </a>
      </div>

      <!-- Legal Links Section -->
      <div class="flex flex-col gap-4">
        <h3 class="font-semibold text-foreground">
          {locale === "de" ? "Rechtliches" : "Legal"}
        </h3>
        <nav class="flex flex-col gap-2" aria-label={locale === "de" ? "Rechtliche Links" : "Legal links"}>
          {
            legalLinks.map((link) => (
              <a
                href={link.href}
                class="text-sm text-muted-foreground hover:text-foreground transition-colors"
              >
                {link.label}
              </a>
            ))
          }
          <!-- Cookie Settings Link -->
          <button
            type="button"
            id="cookie-settings-btn"
            class="text-left text-sm text-muted-foreground hover:text-foreground transition-colors cursor-pointer"
          >
            {cookieSettingsLabel}
          </button>
        </nav>
      </div>

      <!-- Social Links Section -->
      <div class="flex flex-col gap-4">
        <h3 class="font-semibold text-foreground">
          {locale === "de" ? "Folgen Sie mir" : "Follow Me"}
        </h3>
        <div class="flex gap-3">
          {
            socialLinks.map((social) => (
              <a
                href={social.href}
                target="_blank"
                rel="noopener noreferrer"
                aria-label={social.label}
                class="inline-flex h-10 w-10 items-center justify-center rounded-full border border-border text-muted-foreground hover:bg-muted hover:text-foreground transition-colors"
              >
                {social.icon === "linkedin" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                    <rect width="4" height="12" x="2" y="9" />
                    <circle cx="4" cy="4" r="2" />
                  </svg>
                )}
                {social.icon === "github" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" />
                    <path d="M9 18c-4.51 2-5-2-7-2" />
                  </svg>
                )}
                {social.icon === "twitter" && (
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="20"
                    height="20"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="border-t border-border my-8"></div>

    <!-- Bottom Section -->
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-sm text-muted-foreground">
        {copyright}
      </p>
    </div>
  </div>
</footer>

<script>
  // Cookie settings button: dispatch custom event to re-show the consent banner
  const cookieBtn = document.getElementById("cookie-settings-btn");
  cookieBtn?.addEventListener("click", () => {
    window.dispatchEvent(new CustomEvent("show-cookie-consent"));
  });
</script>
