---
import { getContent } from "@/lib/content";
import type { Locale } from "@/lib/types";
import { Input } from "./starwind/input";
import { Textarea } from "./starwind/textarea";
import { Label } from "./starwind/label";
import { Button } from "./starwind/button";

interface Props {
  locale?: Locale;
}

const { locale = "de" } = Astro.props;
const content = getContent(locale);
const { contact } = content;

const thankYouUrl = locale === "en" ? "/en/thank-you" : "/danke";
---

<section id="contact" class="py-12 sm:py-16 md:py-20 lg:py-24 bg-muted/30">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="max-w-3xl mx-auto text-center mb-12 sm:mb-16">
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6">
        {contact.sectionTitle}
      </h2>
      <p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
        {contact.sectionSubtitle}
      </p>
    </div>

    <div class="max-w-2xl mx-auto">
      <!-- Contact Form -->
      <form
        id="contact-form"
        class="space-y-6 bg-card rounded-lg border border-border p-6 sm:p-8"
        novalidate
        data-thank-you-url={thankYouUrl}
        data-success-message={contact.form.successMessage}
        data-error-message={contact.form.errorMessage}
        data-required-error={contact.form.requiredFieldError}
        data-email-error={contact.form.invalidEmailError}
      >
        <!-- Name Field -->
        <div class="space-y-2">
          <Label for="contact-name">{contact.form.namePlaceholder}</Label>
          <Input
            type="text"
            id="contact-name"
            name="name"
            placeholder={contact.form.namePlaceholder}
            required
            autocomplete="name"
          />
          <p class="text-sm text-destructive hidden" data-error="name"></p>
        </div>

        <!-- Email Field -->
        <div class="space-y-2">
          <Label for="contact-email">{contact.form.emailPlaceholder}</Label>
          <Input
            type="email"
            id="contact-email"
            name="email"
            placeholder={contact.form.emailPlaceholder}
            required
            autocomplete="email"
          />
          <p class="text-sm text-destructive hidden" data-error="email"></p>
        </div>

        <!-- Message Field -->
        <div class="space-y-2">
          <Label for="contact-message">{contact.form.messagePlaceholder}</Label>
          <Textarea
            id="contact-message"
            name="message"
            placeholder={contact.form.messagePlaceholder}
            required
            rows={5}
          />
          <p class="text-sm text-destructive hidden" data-error="message"></p>
        </div>

        <!-- Honeypot field (hidden from humans, bots fill it in) -->
        <div class="hidden" aria-hidden="true">
          <label for="contact-website">Website</label>
          <input type="text" id="contact-website" name="website" tabindex="-1" autocomplete="off" />
        </div>

        <!-- Cloudflare Turnstile Widget -->
        <div class="cf-turnstile" data-sitekey="1x00000000000000000000AA" data-theme="auto"></div>

        <!-- Submit Button -->
        <Button type="submit" variant="primary" class="w-full" id="contact-submit">
          {contact.form.submitLabel}
        </Button>

        <!-- Status Messages -->
        <div id="form-success" class="hidden rounded-md bg-green-50 dark:bg-green-950/30 border border-green-200 dark:border-green-800 p-4 text-sm text-green-700 dark:text-green-300" role="alert">
          {contact.form.successMessage}
        </div>
        <div id="form-error" class="hidden rounded-md bg-destructive/10 border border-destructive/30 p-4 text-sm text-destructive" role="alert">
          {contact.form.errorMessage}
        </div>
      </form>

      <!-- Alternative Contact -->
      <div class="mt-8 text-center">
        <p class="text-muted-foreground">
          {contact.emailLabel}
        </p>
        <a
          href={`mailto:${contact.emailAddress}`}
          class="text-primary hover:text-primary/80 font-medium transition-colors"
        >
          {contact.emailAddress}
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Cloudflare Turnstile Script -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;

  if (form) {
    const thankYouUrl = form.dataset.thankYouUrl || "/danke";
    const requiredError = form.dataset.requiredError || "This field is required.";
    const emailError = form.dataset.emailError || "Please enter a valid email address.";

    const successEl = document.getElementById("form-success");
    const errorEl = document.getElementById("form-error");

    function showFieldError(fieldName: string, message: string) {
      const errorP = form!.querySelector(`[data-error="${fieldName}"]`) as HTMLElement | null;
      const input = form!.querySelector(`[name="${fieldName}"]`) as HTMLElement | null;
      if (errorP) {
        errorP.textContent = message;
        errorP.classList.remove("hidden");
      }
      if (input) {
        input.setAttribute("aria-invalid", "true");
      }
    }

    function clearFieldError(fieldName: string) {
      const errorP = form!.querySelector(`[data-error="${fieldName}"]`) as HTMLElement | null;
      const input = form!.querySelector(`[name="${fieldName}"]`) as HTMLElement | null;
      if (errorP) {
        errorP.textContent = "";
        errorP.classList.add("hidden");
      }
      if (input) {
        input.removeAttribute("aria-invalid");
      }
    }

    function clearAllErrors() {
      ["name", "email", "message"].forEach(clearFieldError);
      successEl?.classList.add("hidden");
      errorEl?.classList.add("hidden");
    }

    function isValidEmail(email: string): boolean {
      return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);
    }

    function validateForm(): boolean {
      let valid = true;
      clearAllErrors();

      const nameInput = form!.querySelector('[name="name"]') as HTMLInputElement;
      const emailInput = form!.querySelector('[name="email"]') as HTMLInputElement;
      const messageInput = form!.querySelector('[name="message"]') as HTMLTextAreaElement;

      if (!nameInput.value.trim()) {
        showFieldError("name", requiredError);
        valid = false;
      }

      if (!emailInput.value.trim()) {
        showFieldError("email", requiredError);
        valid = false;
      } else if (!isValidEmail(emailInput.value.trim())) {
        showFieldError("email", emailError);
        valid = false;
      }

      if (!messageInput.value.trim()) {
        showFieldError("message", requiredError);
        valid = false;
      }

      return valid;
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      clearAllErrors();

      // Honeypot check — if filled, silently reject (bot detected)
      const honeypot = form.querySelector('[name="website"]') as HTMLInputElement;
      if (honeypot && honeypot.value) {
        // Fake success to not reveal detection
        successEl?.classList.remove("hidden");
        return;
      }

      if (!validateForm()) {
        return;
      }

      const submitBtn = document.getElementById("contact-submit") as HTMLButtonElement;
      submitBtn.disabled = true;

      try {
        const formData = new FormData(form);
        // Remove honeypot field from submission
        formData.delete("website");
        const data = Object.fromEntries(formData.entries());

        const response = await fetch("https://contact.jonaswestphal.de/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          successEl?.classList.remove("hidden");
          form.reset();
          // Redirect to thank-you page after a brief delay
          setTimeout(() => {
            window.location.href = thankYouUrl;
          }, 1500);
        } else if (response.status === 429) {
          // Rate limited — show specific message
          errorEl!.textContent = form.dataset.rateLimitError || "Zu viele Anfragen. Bitte versuchen Sie es später erneut.";
          errorEl?.classList.remove("hidden");
        } else {
          errorEl?.classList.remove("hidden");
        }
      } catch {
        errorEl?.classList.remove("hidden");
      } finally {
        // Keep button disabled for 10 seconds to prevent rapid resubmission
        setTimeout(() => {
          submitBtn.disabled = false;
        }, 10000);
      }
    });

    // Clear individual field errors on input
    ["name", "email", "message"].forEach((fieldName) => {
      const input = form.querySelector(`[name="${fieldName}"]`);
      input?.addEventListener("input", () => clearFieldError(fieldName));
    });
  }
</script>
