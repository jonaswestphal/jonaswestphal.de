---
import type { TimelineEntry as TimelineEntryType } from "@/lib/types";

interface Props {
  entry: TimelineEntryType;
  index: number;
}

const { entry, index } = Astro.props;
const isEven = index % 2 === 0;
---

<div class="relative flex items-start gap-6 md:gap-0">
	<!-- Desktop: alternating left/right layout -->
	<div class:list={[
		"hidden md:flex md:w-1/2",
		isEven ? "md:justify-end md:pr-8" : "md:order-2 md:pl-8",
	]}>
		<div class="max-w-md">
			<span class="inline-block text-sm font-semibold text-primary mb-1">{entry.period}</span>
			<h3 class="text-lg font-bold text-foreground">{entry.role}</h3>
			<p class="text-sm font-medium text-muted-foreground mb-2">{entry.company}</p>
			<p class="text-muted-foreground leading-relaxed">{entry.description}</p>
		</div>
	</div>

	<!-- Center dot (desktop) -->
	<div class="hidden md:flex absolute left-1/2 -translate-x-1/2 top-1">
		<div class="h-4 w-4 rounded-full bg-primary border-4 border-background ring-2 ring-primary/30"></div>
	</div>

	<!-- Desktop: empty spacer for the other side -->
	<div class:list={[
		"hidden md:block md:w-1/2",
		isEven ? "md:order-2" : "md:order-1",
	]}></div>

	<!-- Mobile layout -->
	<div class="md:hidden flex items-start gap-4">
		<!-- Mobile dot -->
		<div class="relative mt-1.5 shrink-0">
			<div class="h-3 w-3 rounded-full bg-primary ring-2 ring-primary/30"></div>
		</div>
		<!-- Mobile content -->
		<div>
			<span class="inline-block text-sm font-semibold text-primary mb-1">{entry.period}</span>
			<h3 class="text-lg font-bold text-foreground">{entry.role}</h3>
			<p class="text-sm font-medium text-muted-foreground mb-2">{entry.company}</p>
			<p class="text-muted-foreground leading-relaxed">{entry.description}</p>
		</div>
	</div>
</div>
