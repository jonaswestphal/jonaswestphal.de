---
import { getContent } from "@/lib/content";
import type { Locale } from "@/lib/types";
import StepCard from "./StepCard.astro";

interface Props {
  locale?: Locale;
}

const { locale = "de" } = Astro.props;
const content = getContent(locale);
const { howItWorks } = content;
---

<section id="how-it-works" class="py-12 sm:py-16 md:py-20 lg:py-24 bg-muted/30">
	<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<!-- Section Header -->
		<div class="max-w-3xl mx-auto text-center mb-12 sm:mb-16">
			<h2 class="text-3xl sm:text-4xl md:text-5xl font-bold leading-tight text-foreground mb-4 sm:mb-6">
				{howItWorks.sectionTitle}
			</h2>
			<p class="text-lg sm:text-xl text-muted-foreground leading-relaxed">
				{howItWorks.sectionSubtitle}
			</p>
		</div>

		<!-- Steps Container -->
		<div class="grid gap-8 md:gap-6 grid-cols-1 md:grid-cols-3">
			{howItWorks.steps.map((step) => (
				<StepCard step={step} />
			))}
		</div>
	</div>
</section>
