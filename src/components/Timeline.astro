---
import { getContent } from "@/lib/content";
import type { Locale } from "@/lib/types";
import TimelineEntry from "./TimelineEntry.astro";

interface Props {
  locale?: Locale;
}

const { locale = "de" } = Astro.props;
const content = getContent(locale);
const { timeline } = content;
---

<div>
	<h3 class="text-2xl sm:text-3xl font-bold text-foreground text-center mb-10 sm:mb-14">
		{timeline.sectionTitle}
	</h3>

	<!-- Timeline container -->
	<div class="relative">
		<!-- Vertical line (desktop) -->
		<div class="hidden md:block absolute left-1/2 -translate-x-1/2 top-0 bottom-0 w-0.5 bg-border"></div>

		<!-- Vertical line (mobile) -->
		<div class="md:hidden absolute left-[5px] top-0 bottom-0 w-0.5 bg-border"></div>

		<!-- Timeline entries -->
		<div class="space-y-8 md:space-y-12">
			{timeline.entries.map((entry, index) => (
				<TimelineEntry entry={entry} index={index} />
			))}
		</div>
	</div>
</div>
